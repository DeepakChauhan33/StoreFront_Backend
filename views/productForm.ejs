<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Product Form</title>
</head>

<body>

  <h2>Add Product</h2>

  <form action="/product/addProduct" method="POST">

    <!-- Product ID -->
    <label for="id">Product ID:</label>
    <input type="number" id="id" name="_id" required>
    <br><br>

    <!-- Title -->
    <label for="title">Title:</label>
    <input type="text" id="title" name="title" required>
    <br><br>

    <!-- Price -->
    <label for="price">Price:</label>
    <input type="text" id="price" name="price" required>
    <br><br>

    <!-- Description -->
    <label for="description">Description:</label>
    <textarea id="description" name="description" required></textarea>
    <br><br>

    <!-- Category -->
    <label for="category">Category:</label>
    <input type="text" id="category" name="category" required>
    <br><br>

    <!-- Stock -->
    <label for="stock">Stock:</label>
    <input type="number" id="stock" name="stock" value="0">
    <br><br>

    <!-- Image URL -->
    <label for="image">Image URL:</label>
    <input type="url" id="image" name="image" required>
    <br><br>

    <h3>Rating</h3>

    <!-- Rating Rate -->
    <label for="rate">Rate (0-5):</label>
    <input type="number" id="rate" name="rating[rate]" min="0" max="5" step="0.1" required>
    <br><br>

    <!-- Rating Count -->
    <label for="count">Rating Count:</label>
    <input type="number" id="count" name="rating[count]" min="0" required>
    <br><br>

    <button type="submit">Add Product</button>

  </form>

</body>

</html>